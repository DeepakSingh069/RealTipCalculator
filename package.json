{
  "name": "real-tip-calculator",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "deploy": "astro build && node -e \"const fs = require('fs'); const p = '.wrangler/deploy/config.json'; if (fs.existsSync(p)) fs.unlinkSync(p);\" && wrangler pages deploy dist --branch main",
    "pages:deploy": "wrangler pages deploy dist --branch main"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.7.0",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.4.4",
    "resend": "^6.12.4",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "wrangler": "^4.98.0"
  }
}
