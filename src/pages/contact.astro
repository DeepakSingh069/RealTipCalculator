---
import PageLayout from "../layouts/PageLayout.astro";
---

<PageLayout
  title="Contact Us — Real Tip Calculator"
  description="Get in touch with the Real Tip Calculator team. We'd love to hear your feedback, suggestions, or bug reports."
  canonicalPath="/contact"
  breadcrumb="Contact Us"
>
  <div>
    <!-- Contact cards row -->
    <div
      style="
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 20px;
      margin-bottom: 56px;
    "
    >
      {
        [
          {
            icon: "✉️",
            title: "Email Us",
            value: "info@elevenxsolutions.com",
            href: "mailto:lifeturningpoint@gmail.com",
          },
          {
            icon: "🌐",
            title: "Website",
            value: "realtipcalculator.com",
            href: "/",
          },
          {
            icon: "🐦",
            title: "Twitter / X",
            value: "@DeepakShips",
            href: "https://x.com/DeepakShips",
          },
        ].map((card) => (
          <a
            href={card.href}
            style="
          display: flex; flex-direction: column; align-items: center; text-align: center;
          background: linear-gradient(135deg, #faf8ff, #f3f0ff);
          border: 1.5px solid #e9d5ff; border-radius: 16px;
          padding: 28px 20px; text-decoration: none;
          transition: all 0.2s ease;
        "
            onmouseover="this.style.borderColor='#7c3aed'; this.style.boxShadow='0 8px 24px rgba(124,58,237,0.15)';"
            onmouseout="this.style.borderColor='#e9d5ff'; this.style.boxShadow='none';"
          >
            <span style="font-size: 28px; margin-bottom: 10px;">
              {card.icon}
            </span>
            <span style="font-family:'Manrope',sans-serif; font-size:15px; font-weight:700; color:#1e1b4b; margin-bottom:6px;">
              {card.title}
            </span>
            <span style="font-family:'DM Sans',sans-serif; font-size:14px; color:#7c3aed;">
              {card.value}
            </span>
          </a>
        ))
      }
    </div>

    <!-- Contact form -->
    <div
      style="
      background: linear-gradient(135deg, #faf8ff, #f3f0ff);
      border: 1.5px solid #e9d5ff;
      border-radius: 20px;
      padding: 48px;
    "
    >
      <h2
        style="
        font-family:'Manrope',sans-serif; font-size:28px;
        font-weight:800; color:#1e1b4b; margin:0 0 8px;
        letter-spacing:-0.5px;
      "
      >
        Send us a message
      </h2>
      <p
        style="font-family:'DM Sans',sans-serif; font-size:15px; color:#6b7280; margin:0 0 36px;"
      >
        Have a question, found a bug, or have a feature idea? We read every
        message.
      </p>

      <form
        id="contact-form"
        style="display:flex; flex-direction:column; gap:20px;"
      >
        <!-- Status message container -->
        <div
          id="form-status"
          style="display:none; padding:12px 16px; border-radius:10px; font-family:'DM Sans',sans-serif; font-size:14px; text-align:center;"
        >
        </div>

        <div
          style="display:grid; grid-template-columns:1fr 1fr; gap:20px;"
          id="name-email-row"
        >
          <div>
            <label
              for="contact-name"
              style="
              display:block; font-family:'DM Sans',sans-serif; font-size:13px;
              font-weight:700; color:#7c3aed; letter-spacing:0.8px;
              text-transform:uppercase; margin-bottom:8px;
            "
              >Your Name</label
            >
            <input
              type="text"
              id="contact-name"
              name="name"
              placeholder="John Smith"
              required
              style="
                width:100%; box-sizing:border-box;
                background:#ffffff; color:#1e1b4b;
                font-family:'DM Sans',sans-serif; font-size:15px;
                padding:12px 16px; border-radius:10px;
                border:1.5px solid #e9d5ff;
                outline:none; transition:border-color 0.15s ease;
              "
              onfocus="this.style.borderColor='#7c3aed'; this.style.boxShadow='0 0 0 3px rgba(124,58,237,0.1)';"
              onblur="this.style.borderColor='#e9d5ff'; this.style.boxShadow='none';"
            />
          </div>
          <div>
            <label
              for="contact-email"
              style="
              display:block; font-family:'DM Sans',sans-serif; font-size:13px;
              font-weight:700; color:#7c3aed; letter-spacing:0.8px;
              text-transform:uppercase; margin-bottom:8px;
            "
              >Email Address</label
            >
            <input
              type="email"
              id="contact-email"
              name="email"
              placeholder="you@example.com"
              required
              style="
                width:100%; box-sizing:border-box;
                background:#ffffff; color:#1e1b4b;
                font-family:'DM Sans',sans-serif; font-size:15px;
                padding:12px 16px; border-radius:10px;
                border:1.5px solid #e9d5ff;
                outline:none; transition:border-color 0.15s ease;
              "
              onfocus="this.style.borderColor='#7c3aed'; this.style.boxShadow='0 0 0 3px rgba(124,58,237,0.1)';"
              onblur="this.style.borderColor='#e9d5ff'; this.style.boxShadow='none';"
            />
          </div>
        </div>

        <div>
          <label
            for="contact-subject"
            style="
            display:block; font-family:'DM Sans',sans-serif; font-size:13px;
            font-weight:700; color:#7c3aed; letter-spacing:0.8px;
            text-transform:uppercase; margin-bottom:8px;
          "
            >Subject</label
          >
          <select
            id="contact-subject"
            name="subject"
            style="
            width:100%; background:#ffffff; color:#1e1b4b;
            font-family:'DM Sans',sans-serif; font-size:15px;
            padding:12px 16px; border-radius:10px;
            border:1.5px solid #e9d5ff;
            outline:none; cursor:pointer;
          "
          >
            <option value="feedback">💬 General Feedback</option>
            <option value="bug">🐛 Report a Bug</option>
            <option value="feature">✨ Feature Request</option>
            <option value="seo">📊 SEO / Content Suggestion</option>
            <option value="other">📋 Other</option>
          </select>
        </div>

        <div>
          <label
            for="contact-message"
            style="
            display:block; font-family:'DM Sans',sans-serif; font-size:13px;
            font-weight:700; color:#7c3aed; letter-spacing:0.8px;
            text-transform:uppercase; margin-bottom:8px;
          "
            >Message</label
          >
          <textarea
            id="contact-message"
            name="message"
            placeholder="Tell us what's on your mind..."
            required
            rows="5"
            style="
              width:100%; box-sizing:border-box; resize:vertical;
              background:#ffffff; color:#1e1b4b;
              font-family:'DM Sans',sans-serif; font-size:15px;
              padding:12px 16px; border-radius:10px;
              border:1.5px solid #e9d5ff;
              outline:none; transition:border-color 0.15s ease;
              line-height:1.6;
            "
            onfocus="this.style.borderColor='#7c3aed'; this.style.boxShadow='0 0 0 3px rgba(124,58,237,0.1)';"
            onblur="this.style.borderColor='#e9d5ff'; this.style.boxShadow='none';"
          ></textarea>
        </div>

        <button
          type="submit"
          id="contact-submit"
          style="
          display:flex; align-items:center; justify-content:center; gap:8px;
          background:linear-gradient(135deg,#7c3aed,#6d28d9);
          color:#ffffff; border:none; border-radius:12px;
          font-family:'DM Sans',sans-serif; font-size:16px; font-weight:700;
          padding:14px 32px; cursor:pointer; align-self:flex-start;
          box-shadow:0 4px 16px rgba(124,58,237,0.35);
          transition:all 0.2s ease;
        "
          onmouseover="this.style.transform='translateY(-1px)'; this.style.boxShadow='0 6px 20px rgba(124,58,237,0.45)';"
          onmouseout="this.style.transform='none'; this.style.boxShadow='0 4px 16px rgba(124,58,237,0.35)';"
        >
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
          >
            <line x1="22" y1="2" x2="11" y2="13"></line><polygon
              points="22 2 15 22 11 13 2 9 22 2"></polygon>
          </svg>
          Send Message
        </button>
      </form>
    </div>

    <!-- FAQ nudge -->
    <div
      style="
      margin-top: 40px; padding: 24px 28px;
      background: rgba(124,58,237,0.06);
      border: 1px solid rgba(124,58,237,0.15);
      border-radius: 14px;
      display: flex; align-items: center; gap: 16px;
    "
    >
      <span style="font-size:28px; flex-shrink:0;">❓</span>
      <div>
        <p
          style="font-family:'Manrope',sans-serif; font-size:15px; font-weight:700; color:#1e1b4b; margin:0 0 4px;"
        >
          Looking for quick answers?
        </p>
        <p
          style="font-family:'DM Sans',sans-serif; font-size:14px; color:#6b7280; margin:0;"
        >
          Check our <a
            href="/#faq"
            style="color:#7c3aed; text-decoration:underline;">FAQ section</a
          > — we've answered 30+ common tipping questions.
        </p>
      </div>
    </div>
  </div>
</PageLayout>

<style>
  /* Dark mode for contact page */
  [data-theme="dark"] #contact-form div > div > a,
  [data-theme="dark"] .contact-card {
    background: rgba(124, 58, 237, 0.1) !important;
    border-color: rgba(196, 181, 253, 0.2) !important;
  }
  [data-theme="dark"] #contact-form > div:first-child {
    background: rgba(124, 58, 237, 0.08) !important;
    border-color: rgba(196, 181, 253, 0.2) !important;
  }
  [data-theme="dark"] input,
  [data-theme="dark"] textarea,
  [data-theme="dark"] select {
    background: #1e1357 !important;
    color: #e9d5ff !important;
    border-color: rgba(196, 181, 253, 0.2) !important;
  }
  [data-theme="dark"] input::placeholder,
  [data-theme="dark"] textarea::placeholder {
    color: #5b4b8a !important;
  }
  [data-theme="dark"] h2 {
    color: #e9d5ff !important;
  }
  [data-theme="dark"] p {
    color: #a78bfa !important;
  }

  @media (max-width: 600px) {
    #name-email-row {
      grid-template-columns: 1fr !important;
    }
    #contact-form > div:nth-child(4) > div[style*="padding:48px"] {
      padding: 24px !important;
    }
  }
</style>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const submitBtn = document.getElementById(
    "contact-submit",
  ) as HTMLButtonElement;
  const statusDiv = document.getElementById("form-status") as HTMLDivElement;

  if (form) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      // Update UI to loading state
      const originalBtnText = submitBtn.innerHTML;
      submitBtn.innerHTML = "Sending...";
      submitBtn.disabled = true;
      submitBtn.style.opacity = "0.7";
      submitBtn.style.cursor = "not-allowed";

      statusDiv.style.display = "none";

      // Gather form data
      const formData = new FormData(form);
      const data = Object.fromEntries(formData.entries());

      try {
        const response = await fetch("/api/contact", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(data),
        });

        const result = await response.json();

        statusDiv.style.display = "block";

        if (response.ok) {
          // Success
          statusDiv.style.backgroundColor = "rgba(16, 185, 129, 0.1)";
          statusDiv.style.border = "1px solid #10b981";
          statusDiv.style.color = "#059669";
          statusDiv.innerText = "✅ Your message has been sent successfully!";
          form.reset();
        } else {
          // Server error
          statusDiv.style.backgroundColor = "rgba(239, 68, 68, 0.1)";
          statusDiv.style.border = "1px solid #ef4444";
          statusDiv.style.color = "#dc2626";
          statusDiv.innerText = `❌ Error: ${result.error || "Failed to send message."}`;
        }
      } catch (error) {
        // Network/Client error
        statusDiv.style.display = "block";
        statusDiv.style.backgroundColor = "rgba(239, 68, 68, 0.1)";
        statusDiv.style.border = "1px solid #ef4444";
        statusDiv.style.color = "#dc2626";
        statusDiv.innerText = "❌ A network error occurred. Please try again.";
      } finally {
        // Reset button
        submitBtn.innerHTML = originalBtnText;
        submitBtn.disabled = false;
        submitBtn.style.opacity = "1";
        submitBtn.style.cursor = "pointer";
      }
    });
  }
</script>
