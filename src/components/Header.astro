---
// Header — sticky frosted glass, mobile-responsive with working drawer
---

<header
  id="site-header"
  style="
    position: sticky; top: 0; z-index: 100;
    background-color: rgba(255,255,255,0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid #e9d5ff;
    height: 64px; display: flex; align-items: center;
  "
>
  <div class="container-site" style="display:flex; align-items:center; justify-content:space-between; width:100%; gap:12px;">

    <!-- ── Logo ── -->
    <a href="/" id="site-logo" aria-label="Real Tip Calculator home"
      style="display:flex; align-items:center; gap:10px; text-decoration:none; flex-shrink:0;">
      <img
        src="/favicon-96x96.png"
        alt="Real Tip Calculator logo"
        width="34"
        height="34"
        style="
          width:34px; height:34px; border-radius:9px; flex-shrink:0;
          box-shadow:0 4px 12px rgba(124,58,237,0.35);
          display:block;
        "
      />
      <span style="
        font-family:'Manrope',sans-serif; font-size:15px; font-weight:800;
        color:#1e1b4b; letter-spacing:-0.4px; white-space:nowrap;
      ">Real Tip Calculator</span>
    </a>

    <!-- ── Desktop nav (hidden on mobile) ── -->
    <nav id="desktop-nav" aria-label="Main navigation" style="display:flex; align-items:center; gap:4px; flex:1; justify-content:flex-end;">
      {[
        ["How it works", "/#how-it-works"],
        ["Country Guide", "/#country-guide"],
        ["FAQ",          "/#faq"],
        ["About",        "/about"],
        ["Contact",      "/contact"],
      ].map(([label, href]) => (
        <a
          href={href}
          style="
            font-family:'DM Sans',sans-serif; font-size:14px; font-weight:500;
            color:#6b7280; text-decoration:none; padding:8px 14px; border-radius:8px;
            transition:all 0.15s ease; white-space:nowrap;
          "
          onmouseover="this.style.color='#7c3aed'; this.style.backgroundColor='#faf8ff';"
          onmouseout="this.style.color='#6b7280'; this.style.backgroundColor='transparent';"
        >{label}</a>
      ))}

      <!-- ── More ▾ dropdown ── -->
      <div class="nav-dropdown-wrap">
        <button class="nav-dropdown-btn" aria-haspopup="true" aria-label="More pages">
          More
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
            <path d="M6 9l6 6 6-6"/>
          </svg>
        </button>
        <div class="nav-dropdown-panel" role="menu">
          <a href="/privacy-policy" class="nav-dropdown-item" role="menuitem">
            <span style="font-size:14px;">🔒</span> Privacy Policy
          </a>
          <a href="/terms" class="nav-dropdown-item" role="menuitem">
            <span style="font-size:14px;">📋</span> Terms &amp; Conditions
          </a>
        </div>
      </div>

      <button
        id="header-share-btn"
        onclick="if(navigator.share){navigator.share({title:'Real Tip Calculator',url:window.location.href});}else{navigator.clipboard.writeText(window.location.href).then(()=>{const t=document.getElementById('header-share-btn');const orig=t.innerHTML;t.textContent='Copied!';setTimeout(()=>{t.innerHTML=orig;},2000);});}"
        style="
          display:flex; align-items:center; gap:6px;
          font-family:'DM Sans',sans-serif; font-size:14px; font-weight:700;
          color:#7c3aed; background:#faf8ff; border:1.5px solid #e9d5ff;
          padding:9px 18px; height:38px; border-radius:8px; cursor:pointer;
          transition:all 0.15s ease; margin-left:8px; white-space:nowrap;
        "
        onmouseover="this.style.backgroundColor='#ede9fe'; this.style.borderColor='#7c3aed';"
        onmouseout="this.style.backgroundColor='#faf8ff'; this.style.borderColor='#e9d5ff';"
      >
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
          <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/>
        </svg>
        Share
      </button>
    </nav>

    <!-- ── Right side: dark toggle + hamburger (always visible) ── -->
    <div style="display:flex; align-items:center; gap:8px; flex-shrink:0;">

      <!-- Dark mode toggle — ALWAYS visible on all screen sizes -->
      <button
        id="theme-toggle"
        aria-label="Toggle dark mode"
        title="Toggle dark mode"
      >
        <!-- Moon icon — shown in light mode -->
        <svg class="icon-moon" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#7c3aed" stroke-width="2" stroke-linecap="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
        <!-- Sun icon — shown in dark mode -->
        <svg class="icon-sun" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#c4b5fd" stroke-width="2" stroke-linecap="round">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
      </button>

      <!-- Hamburger — mobile only -->
      <button
        id="mobile-menu-btn"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-drawer"
        style="display:none;"
      >
        <!-- Hamburger icon -->
        <svg id="hamburger-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
        <!-- Close icon -->
        <svg id="close-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" style="display:none;">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
  </div>
</header>

<!-- ── Mobile Drawer ── -->
<div
  id="mobile-drawer"
  aria-hidden="true"
  style="
    display: none;
    position: fixed;
    top: 64px; left: 0; right: 0;
    z-index: 99;
    background-color: rgba(255,255,255,0.98);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid #e9d5ff;
    padding: 16px 20px 24px;
    flex-direction: column;
    gap: 4px;
    box-shadow: 0 12px 40px rgba(124,58,237,0.12);
    animation: slideDown 0.2s ease;
  "
>
  <!-- Main nav links -->
  <div style="padding-bottom:8px; border-bottom:1px solid #e9d5ff; margin-bottom:8px;">
    <p style="font-family:'DM Sans',sans-serif; font-size:11px; font-weight:700; color:#a78bfa; letter-spacing:1.2px; text-transform:uppercase; padding:8px 16px 4px; margin:0;">Calculator</p>
    {[
      ["How it works",  "/#how-it-works"],
      ["Country Guide", "/#country-guide"],
      ["FAQ",           "/#faq"],
    ].map(([label, href]) => (
      <a
        href={href}
        class="mobile-nav-link"
        style="
          font-family:'DM Sans',sans-serif; font-size:15px; font-weight:600;
          color:#1e1b4b; text-decoration:none;
          padding:11px 16px; border-radius:10px;
          border: 1px solid transparent;
          transition:all 0.15s ease;
          display:block;
        "
      >{label}</a>
    ))}
  </div>

  <!-- Company pages -->
  <div style="padding-bottom:12px; border-bottom:1px solid #e9d5ff; margin-bottom:12px;">
    <p style="font-family:'DM Sans',sans-serif; font-size:11px; font-weight:700; color:#a78bfa; letter-spacing:1.2px; text-transform:uppercase; padding:8px 16px 4px; margin:0;">Company</p>
    {[
      ["🏠 About Us",          "/about"],
      ["✉️ Contact Us",        "/contact"],
      ["🔒 Privacy Policy",    "/privacy-policy"],
      ["📋 Terms & Conditions", "/terms"],
    ].map(([label, href]) => (
      <a
        href={href}
        class="mobile-nav-link"
        style="
          font-family:'DM Sans',sans-serif; font-size:15px; font-weight:600;
          color:#1e1b4b; text-decoration:none;
          padding:11px 16px; border-radius:10px;
          border: 1px solid transparent;
          transition:all 0.15s ease;
          display:block;
        "
      >{label}</a>
    ))}
  </div>

  <!-- Share button in drawer -->
  <button
    id="mobile-share-btn"
    onclick="if(navigator.share){navigator.share({title:'Real Tip Calculator',url:window.location.href});}else{navigator.clipboard.writeText(window.location.href).then(()=>{const t=document.getElementById('mobile-share-btn');const orig=t.textContent;t.textContent='Link copied!';setTimeout(()=>t.textContent=orig,2000);});}"
    style="
      width:100%; display:flex; align-items:center; justify-content:center; gap:8px;
      font-family:'DM Sans',sans-serif; font-size:15px; font-weight:700;
      color:#7c3aed; background:#faf8ff; border:1.5px solid #e9d5ff;
      padding:12px 20px; border-radius:10px; cursor:pointer; transition:all 0.15s ease;
    "
  >
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
      <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/>
    </svg>
    Share this tool
  </button>
</div>

<!-- Backdrop overlay -->
<div
  id="mobile-backdrop"
  style="
    display:none;
    position:fixed; inset:0; top:64px;
    z-index:98;
    background:rgba(0,0,0,0.25);
    backdrop-filter:blur(2px);
  "
></div>

<style>
  /* ── Desktop: hide hamburger ── */
  @media (min-width: 769px) {
    #mobile-menu-btn  { display: none !important; }
    #mobile-drawer    { display: none !important; }
    #mobile-backdrop  { display: none !important; }
  }

  /* ── More dropdown ── */
  .nav-dropdown-wrap {
    position: relative;
    display: flex;
    align-items: center;
  }
  .nav-dropdown-btn {
    display: flex;
    align-items: center;
    gap: 5px;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: #6b7280;
    background: transparent;
    border: none;
    padding: 8px 14px;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.15s ease;
    white-space: nowrap;
  }
  .nav-dropdown-btn:hover,
  .nav-dropdown-wrap:hover .nav-dropdown-btn {
    color: #7c3aed;
    background-color: #faf8ff;
  }
  .nav-dropdown-panel {
    display: none;
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    min-width: 200px;
    background: #ffffff;
    border: 1.5px solid #e9d5ff;
    border-radius: 12px;
    box-shadow: 0 12px 32px rgba(124,58,237,0.15);
    padding: 6px;
    z-index: 200;
    animation: dropFade 0.15s ease;
  }
  .nav-dropdown-wrap:hover .nav-dropdown-panel,
  .nav-dropdown-wrap:focus-within .nav-dropdown-panel {
    display: flex;
    flex-direction: column;
  }
  .nav-dropdown-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: #374151;
    text-decoration: none;
    padding: 10px 14px;
    border-radius: 8px;
    transition: all 0.12s ease;
  }
  .nav-dropdown-item:hover {
    background: #faf8ff;
    color: #7c3aed;
  }
  @keyframes dropFade {
    from { opacity: 0; transform: translateY(-6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Dark mode dropdown */
  [data-theme="dark"] .nav-dropdown-panel {
    background: #1e1357;
    border-color: rgba(196,181,253,0.2);
  }
  [data-theme="dark"] .nav-dropdown-item {
    color: #c4b5fd;
  }
  [data-theme="dark"] .nav-dropdown-item:hover {
    background: rgba(124,58,237,0.2);
    color: #ffffff;
  }
  [data-theme="dark"] .nav-dropdown-btn {
    color: #8b75d9;
  }
  [data-theme="dark"] .nav-dropdown-btn:hover,
  [data-theme="dark"] .nav-dropdown-wrap:hover .nav-dropdown-btn {
    color: #c4b5fd;
    background: rgba(124,58,237,0.15);
  }

  /* ── Mobile: hide desktop nav ── */
  @media (max-width: 768px) {
    #desktop-nav      { display: none !important; }
    #mobile-menu-btn  { display: flex !important; }
  }

  /* Mobile hamburger button base style */
  #mobile-menu-btn {
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 10px;
    border: 1.5px solid #e9d5ff;
    background: #faf8ff;
    cursor: pointer;
    color: #7c3aed;
    transition: all 0.15s ease;
  }
  #mobile-menu-btn:hover,
  #mobile-menu-btn[aria-expanded="true"] {
    background: #ede9fe;
    border-color: #7c3aed;
  }

  /* Drawer animation */
  @keyframes slideDown {
    from { opacity: 0; transform: translateY(-8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Mobile nav link hover */
  .mobile-nav-link:hover {
    background: #faf8ff !important;
    border-color: #e9d5ff !important;
    color: #7c3aed !important;
  }

  /* Dark mode: drawer */
  [data-theme="dark"] #mobile-drawer {
    background-color: rgba(19, 12, 53, 0.98) !important;
    border-bottom-color: rgba(196, 181, 253, 0.15) !important;
    box-shadow: 0 12px 40px rgba(0,0,0,0.5) !important;
  }
  [data-theme="dark"] .mobile-nav-link {
    color: #e9d5ff !important;
  }
  [data-theme="dark"] .mobile-nav-link:hover {
    background: rgba(124, 58, 237, 0.15) !important;
    border-color: rgba(196, 181, 253, 0.2) !important;
    color: #ffffff !important;
  }
  [data-theme="dark"] #mobile-drawer > div {
    border-top-color: rgba(196, 181, 253, 0.15) !important;
  }
  [data-theme="dark"] #mobile-share-btn {
    background: rgba(124, 58, 237, 0.15) !important;
    border-color: rgba(196, 181, 253, 0.25) !important;
    color: #a78bfa !important;
  }
  [data-theme="dark"] #mobile-menu-btn {
    background: rgba(124, 58, 237, 0.15) !important;
    border-color: rgba(196, 181, 253, 0.25) !important;
    color: #c4b5fd !important;
  }
</style>

<script>
  // ── Dark mode toggle ──────────────────────────────────────────
  const themeToggle = document.getElementById('theme-toggle')!;
  const html = document.documentElement;

  themeToggle.addEventListener('click', () => {
    const isDark   = html.getAttribute('data-theme') === 'dark';
    const newTheme = isDark ? 'light' : 'dark';
    html.setAttribute('data-theme', newTheme);
    try { localStorage.setItem('rtc-theme', newTheme); } catch (e) {}
  });

  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
    if (!localStorage.getItem('rtc-theme')) {
      html.setAttribute('data-theme', e.matches ? 'dark' : 'light');
    }
  });

  // ── Mobile menu toggle ────────────────────────────────────────
  const menuBtn    = document.getElementById('mobile-menu-btn')!;
  const drawer     = document.getElementById('mobile-drawer')!;
  const backdrop   = document.getElementById('mobile-backdrop')!;
  const hamburger  = document.getElementById('hamburger-icon')!;
  const closeIcon  = document.getElementById('close-icon')!;

  function openMenu() {
    drawer.style.display   = 'flex';
    backdrop.style.display = 'block';
    hamburger.style.display = 'none';
    closeIcon.style.display = 'block';
    menuBtn.setAttribute('aria-expanded', 'true');
    drawer.setAttribute('aria-hidden', 'false');
    // Prevent body scroll
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    drawer.style.display   = 'none';
    backdrop.style.display = 'none';
    hamburger.style.display = 'block';
    closeIcon.style.display = 'none';
    menuBtn.setAttribute('aria-expanded', 'false');
    drawer.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  menuBtn.addEventListener('click', () => {
    const isOpen = menuBtn.getAttribute('aria-expanded') === 'true';
    isOpen ? closeMenu() : openMenu();
  });

  // Close on backdrop click
  backdrop.addEventListener('click', closeMenu);

  // Close when a nav link is tapped (so page scrolls and menu closes)
  drawer.querySelectorAll('a.mobile-nav-link').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  // Close on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMenu();
  });

  // Close menu on resize to desktop
  window.addEventListener('resize', () => {
    if (window.innerWidth > 768) closeMenu();
  });
</script>
